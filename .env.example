# Copy to .env on the VPS (e.g. /var/www/naukrimili/.env).
# GitHub Actions secrets: HOST=76.13.155.103 (or your VPS IP), SSH_USER=root, SSH_PORT=22
# Prisma reads DATABASE_URL only from the environment (see prisma/schema.prisma).

NODE_ENV=production
NEXTAUTH_URL=https://naukrimili.com
NEXTAUTH_SECRET=change-me-min-32-chars
# Set AUTH_DEBUG=true temporarily to log credential/OAuth-check diagnostics (server logs only)
# AUTH_DEBUG=true

# Dev/staging only: allow logged-in users to use resume AI without plan/credits (auth unchanged)
# BYPASS_AI_PAYMENT_CHECKS=true
# ENABLE_AI_DEV_MODE=true

# Resume Builder editor — AI Optimization panel (default: free for signed-in users). Set false to require plan.
# RESUME_OPTIMIZATION_FREE_ACCESS=true
NEXT_PUBLIC_APP_URL=https://naukrimili.com

# PostgreSQL on the same host as the app (production VPS)
DATABASE_URL="postgresql://jobportal_user:Naukrimili%40123@localhost:5432/naukrimili?connection_limit=10&pool_timeout=20&connect_timeout=10&socket_timeout=30"

# Redis (recommended for OTP rate limiting and active OTP storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=true

# MSG91 SMS OTP — set in production; never commit real keys
MSG91_AUTHKEY=
# Flow ID from MSG91 → SMS → Templates (copy icon). DLT Template ID is configured in that template in the panel, not here.
MSG91_FLOW_ID=
MSG91_TEMPLATE_ID=
# DLT-approved Sender ID / Header (6 chars from DLT portal). Must match the template — do not use a display name.
MSG91_SENDER_ID=
# Must match template placeholder: ##OTP## → OTP
MSG91_OTP_VAR=OTP
MSG91_API_URL=https://control.msg91.com/api/v5/flow/

# OTP auth (registration + sign-in) — set true when DLT/MSG91 production is ready
ENABLE_OTP_AUTH=false
NEXT_PUBLIC_ENABLE_OTP_AUTH=false

# OTP settings (service layer; keep when re-enabling OTP)
OTP_ENABLED=true
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_SEND_LOCK_SECONDS=10
OTP_SESSION_TOKEN_TTL_SECONDS=120
OTP_PHONE_VERIFY_TOKEN_TTL_SECONDS=900

# Resume document parsers (set on VPS only — never commit real keys)
# Priority: Affinda → Eden AI → ApiLayer → internal (pdf-parse / mammoth / tesseract / text-recovery)
AFFINDA_API_KEY=
AFFINDA_WORKSPACE_ID=
EDEN_AI_API_KEY=
# Optional: EDEN_AI_RESUME_PROVIDERS=hireability,affinda,sovren
APILAYER_API_KEY=
# Optional: APILAYER_RESUME_PARSER_URL=https://api.apilayer.com/resume_parser/upload
# Optional: APILAYER_TIMEOUT_MS=45000

# External job APIs (set on VPS only — never commit real keys)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
SERPAPI_KEY=
USAJOBS_API_KEY=
# Email registered at https://developer.usajobs.gov (required header)
USAJOBS_USER_AGENT=
ADMIN_SYNC_TOKEN=

# IndexNow (Bing/Yandex URL submission) — verification file in public/{key}.txt
INDEXNOW_KEY=c7d11205cff98387f261807b34d0a8b975bd141091cf9e8e1af5677afb408add
INDEXNOW_ENABLED=true

# Suggested crontab (curl POST /api/jobs/sync with Bearer ADMIN_SYNC_TOKEN):
# IN+US every 6h:  0 */6 * * *
# GB+AE every 12h: 0 */12 * * *  body {"regions":["GB","AE"]}
# Full daily:      0 3 * * *

