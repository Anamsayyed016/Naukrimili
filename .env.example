# Copy to .env on the VPS (e.g. /var/www/naukrimili/.env).
# GitHub Actions secrets: HOST=76.13.155.103 (or your VPS IP), SSH_USER=root, SSH_PORT=22
# Prisma reads DATABASE_URL only from the environment (see prisma/schema.prisma).

NODE_ENV=production
NEXTAUTH_URL=https://naukrimili.com
NEXTAUTH_SECRET=change-me-min-32-chars
# Set AUTH_DEBUG=true temporarily to log credential/OAuth-check diagnostics (server logs only)
# AUTH_DEBUG=true

# Dev/staging only: allow logged-in users to use resume AI without plan/credits (auth unchanged)
# BYPASS_AI_PAYMENT_CHECKS=true
# ENABLE_AI_DEV_MODE=true
NEXT_PUBLIC_APP_URL=https://naukrimili.com

# PostgreSQL on the same host as the app (production VPS)
DATABASE_URL="postgresql://jobportal_user:Naukrimili%40123@localhost:5432/naukrimili?connection_limit=10&pool_timeout=20&connect_timeout=10&socket_timeout=30"

# Redis (recommended for OTP rate limiting and active OTP storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=true

# MSG91 SMS OTP — set in production; never commit real keys
MSG91_AUTHKEY=
# Flow ID from MSG91 → SMS → Templates (copy icon). DLT Template ID is configured in that template in the panel, not here.
MSG91_FLOW_ID=
MSG91_TEMPLATE_ID=
# DLT-approved Sender ID / Header (6 chars from DLT portal). Must match the template — do not use a display name.
MSG91_SENDER_ID=
# Must match template placeholder: ##OTP## → OTP
MSG91_OTP_VAR=OTP
MSG91_API_URL=https://control.msg91.com/api/v5/flow/

# OTP settings
OTP_ENABLED=true
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_SEND_LOCK_SECONDS=10
OTP_SESSION_TOKEN_TTL_SECONDS=120
OTP_PHONE_VERIFY_TOKEN_TTL_SECONDS=900

