# Copy to .env on the VPS (e.g. /var/www/naukrimili/.env).
# GitHub Actions secrets: HOST=76.13.155.103 (or your VPS IP), SSH_USER=root, SSH_PORT=22
# Prisma reads DATABASE_URL only from the environment (see prisma/schema.prisma).

NODE_ENV=production
NEXTAUTH_URL=https://naukrimili.com
NEXTAUTH_SECRET=change-me-min-32-chars
# Set AUTH_DEBUG=true temporarily to log credential/OAuth-check diagnostics (server logs only)
# AUTH_DEBUG=true
NEXT_PUBLIC_APP_URL=https://naukrimili.com

# PostgreSQL on the same host as the app (production VPS)
DATABASE_URL="postgresql://jobportal_user:Naukrimili%40123@localhost:5432/naukrimili?connection_limit=10&pool_timeout=20&connect_timeout=10&socket_timeout=30"
